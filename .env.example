APP_ENV=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://llm_rpg:llm_rpg@localhost:5432/llm_rpg
REDIS_URL=redis://localhost:6379/0

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_STRUCTURED_MODE=auto
LLM_CONTEXT_TOKEN_BUDGET=12000
LLM_TIMEOUT_SECONDS=60
LLM_DISABLE_THINKING=false

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_MODE=webhook
TELEGRAM_WEBHOOK_URL=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_POLLING_RETRY_INITIAL_SECONDS=1
TELEGRAM_POLLING_RETRY_MAX_SECONDS=30

ADMIN_USER_IDS=
LEASE_TTL_SECONDS=120
MAX_PROCESSING_RETRIES=2
RETRY_BACKOFF_SECONDS=5
RATE_LIMIT_TURNS_PER_MINUTE=6
SUGGESTED_ACTIONS_RETAIN_TURNS=5
MEMORY_ENTRY_CAP=80
MEMORY_ENTRY_CHAR_CAP=500
